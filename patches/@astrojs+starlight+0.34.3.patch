+/** moyu: 日刊侧栏链接文案 — `createAt` →「M月d日：」+ title；显式 `sidebar.label` 优先 */
+function moyuDailySidebarLinkLabel(route: Route): string {
+	type FM = {
+		title?: string;
+		createAt?: Date | string;
+		sidebar?: { label?: string };
+	};
+	const data = route.entry.data as FM;
+	const explicit = data.sidebar?.label;
+	if (typeof explicit === 'string' && explicit.trim() !== '') return explicit.trim();
+
+	const slug = route.slug;
+	if (!/^daily\/\d{4}\//.test(slug) || slug.endsWith('/index')) {
+		return (data.title ?? '') as string;
+	}
+
+	const p = data.createAt;
+	let iso = '';
+	if (p instanceof Date && !Number.isNaN(p.getTime())) {
+		iso = p.toISOString().slice(0, 10);
+	} else if (typeof p === 'string' && p.trim()) {
+		const t = new Date(p.trim()).getTime();
+		if (!Number.isNaN(t)) iso = new Date(t).toISOString().slice(0, 10);
+	}
+	const title = ((data.title ?? '') as string).trim();
+	if (!iso) return title;
+	const parts = iso.split('-');
+	const month = parseInt(parts[1]!, 10);
+	const day = parseInt(parts[2]!, 10);
+	const md = `${month}月${day}日`;
+	return title ? `${md}：${title}` : md;
